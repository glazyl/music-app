{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatarSeed": { "type": "string" },
        "photoURL": { "type": "string" },
        "points": { "type": "integer" },
        "totalSteps": { "type": "integer" },
        "unlockedTrackIds": {
          "type": "array"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "points", "totalSteps"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document identified by Firebase Auth UID"
    }
  }
}
