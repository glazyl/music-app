rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Security boundary: force targeted get
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == userId
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'avatarSeed', 'points', 'totalSteps', 'createdAt', 'updatedAt'])
        // We use size() == 7 or more depending on optional fields
        && data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.avatarSeed is string && data.avatarSeed.size() <= 100
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1000000)) // Allowing dataURL
        && data.points is int && data.points >= 0
        && data.totalSteps is int && data.totalSteps >= 0
        && (data.get('unlockedTrackIds', null) == null || (data.unlockedTrackIds is list && data.unlockedTrackIds.size() <= 1000));
    }
  }
}
